{
    "$schema": "https://opencode.ai/config.json",
    "model": "llama-local/qwen3.6-coder",
    "default_agent": "web-agent",
    "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 4096
    },
    "provider": {
        "llama-local": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "llama.cpp local",
            "options": {
                "baseURL": "http://host.docker.internal:8001/v1",
                "timeout": 300000,
                "chunkTimeout": 120000
            },
            "models": {
                "qwen3.6-coder": {
                    "name": "qwen3.6-coder",
                    "tools": true,
                    "limit": {
                        "context": 81920,
                        "output": 8192
                    }
                }
            }
        }
    },
    "mcp": {
        "filesystem": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "/workspaces/extrodata"
            ]
        },
        "memory": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-memory"
            ]
        },
        "sequentialthinking": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        },
        "github": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "dotenv-cli",
                "-e",
                "/workspaces/extrodata/.env",
                "--",
                "npx",
                "-y",
                "@modelcontextprotocol/server-github"
            ]
        }
    },
    "permission": {
        "read": "allow",
        "write": "allow",
        "bash": "allow",
        "mcp": "allow",
        "command": "allow"
    },
    "enabled_providers": [
        "llama-local"
    ]
}